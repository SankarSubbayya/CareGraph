# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# RocketRide — optional per-pipeline webhook URLs (full POST URL). If unset, uses ROCKETRIDE_URI + /webhook.
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=
ROCKETRIDE_CHECKIN_WEBHOOK_URL=
ROCKETRIDE_DRUG_INTERACTION_WEBHOOK_URL=
ROCKETRIDE_CARE_RECOMMENDATION_WEBHOOK_URL=
ROCKETRIDE_CONDITION_SUGGESTION_WEBHOOK_URL=

# GMI Cloud (fallback when RocketRide is unavailable)
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_MODEL=deepseek-ai/DeepSeek-R1

# Bland AI
BLAND_API_KEY=

# App
BASE_URL=http://localhost:8000
