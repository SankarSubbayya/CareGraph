# Optional for local dev: copy to .env (gitignored). Never commit real values.
#
# Team / CI: prefer GitHub Actions and Codespaces secrets — same variable names.
# See .github/SETUP_SECRETS.md

NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Optional Neo4j Aura console metadata (not required by the app)
AURA_INSTANCEID=
AURA_INSTANCENAME=
